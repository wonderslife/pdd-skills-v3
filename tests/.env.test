# ============================================================
# AI Test Framework - 测试环境变量配置
# ============================================================
# 
# 使用方法：
#   1. 复制此文件为 .env.local:  copy .env.test .env.local
#   2. 编辑 .env.local 填入实际值
#   3. 运行测试时会自动加载
#
# 安全提示：
#   - .env.local 已添加到 .gitignore，不会提交到代码库
#   - 绝对禁止将包含真实密码的文件提交到 Git！
#   - 此文件为模板，仅包含默认值/示例值
#

# ============================================================
# 一、测试凭据（必填）
# ============================================================

# 登录用户名
TEST_USER=yuanye

# 登录用户中文名（用于登录状态检测对比）
TEST_DISPLAY_NAME=袁野

# 登录密码（生产环境请使用强密码）
TEST_PASS=yuanye

# ============================================================
# 二、业务测试数据（按需填写）
# ============================================================

# 项目名称（用于资产评估申请等场景）
TEST_PROJECT_NAME=AI自动测试项目-001

# 评估金额（数字格式）
TEST_AMOUNT=1000000

# ============================================================
# 三、被测系统 URL 配置
# ============================================================

# 统一门户登录地址
LOGIN_URL=http://uniportal.sjjk.com.cn

# 资产评估系统地址（可选，如果与门户不同）
ASSET_EVAL_BASE_URL=http://uniportal.sjjk.com.cn

# ============================================================
# 四、LLM 配置（用于智能分析，可选）
# ============================================================

# LLM API 地址
LLM_BASE_URL=http://10.0.11.6:8005/v1

# LLM API 密钥
LLM_API_KEY=APIKEY

# LLM 模型名称
LLM_MODEL=gemma-4-26B-A4B-it

# ============================================================
# 五、浏览器和执行配置（可选）
# ============================================================

# 浏览器类型：chromium / firefox / webkit
BROWSER_TYPE=chromium

# 视口尺寸：1920x1080 / 1366x768 等
BROWSER_VIEWPORT=1920x1080

# 页面加载超时时间（毫秒）
PAGE_TIMEOUT=30000

# 元素操作超时时间（毫秒）
ELEMENT_TIMEOUT=10000

# 是否启用无头模式：true / false
HEADLESS=false

# ============================================================
# 六、调试和日志配置（可选）
# ============================================================

# 日志级别：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# 是否保存页面快照：true / false
SAVE_SNAPSHOTS=true

# 快照保存目录
SNAPSHOT_DIR=./snapshots

# 是否在失败时截图：true / false
SCREENSHOT_ON_FAILURE=true

# 截图保存目录
SCREENSHOT_DIR=./test-result/screenshots

# ============================================================
# 七、重试和容错配置（可选）
# ============================================================

# 全局重试次数
MAX_RETRIES=3

# 重试间隔时间（毫秒）
RETRY_DELAY=1000

# 步骤失败策略：continue / stop / abort
FAILURE_STRATEGY=continue

# 网络请求超时（毫秒）
NETWORK_TIMEOUT=30000
