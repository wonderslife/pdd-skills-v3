class TestConcurrency:
    """并发测试"""

    @pytest.mark.p2
    @pytest.mark.concurrency
    def test_p003_concurrent_list_query(self, api_helper):
        """P003: 并发列表查询"""
        helper, _ = api_helper
        results = []
        errors = []

        def query():
            try:
                resp = helper.get("{{ list_path }}", params={"pageNum": 1, "pageSize": 10})
                results.append(resp.status_code)
            except Exception as e:
                errors.append(str(e))

        with ThreadPoolExecutor(max_workers=10) as executor:
            futures = [executor.submit(query) for _ in range(50)]
            for f in as_completed(futures):
                f.result()

        assert len(errors) == 0, f"Errors occurred: {errors}"
        assert all(r == 200 for r in results)

    @pytest.mark.p2
    @pytest.mark.concurrency
    def test_p004_concurrent_create(self, api_helper, apply_form_valid):
        """P004: 并发创建"""
        helper, _ = api_helper
        results = []

        def create():
            resp = helper.post("{{ create_path }}", json_data=apply_form_valid)
            results.append(resp.status_code)

        with ThreadPoolExecutor(max_workers=5) as executor:
            futures = [executor.submit(create) for _ in range(10)]
            for f in as_completed(futures):
                f.result()

        success_count = sum(1 for r in results if r == 200)
        assert success_count >= 8


