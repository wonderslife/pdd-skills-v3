class TestDataConsistency:
    """数据一致性集成测试"""

    @pytest.mark.p1
    @pytest.mark.integration
    def test_i006_create_and_query_consistency(self, applicant_session, apply_form_valid):
        """I006: 创建后查询数据一致性"""
        helper, token = applicant_session
        resp = helper.post("{{ create_path }}", json_data=apply_form_valid)
        assert resp.status_code == 200
        record_id = resp.json().get("data")

        resp = helper.get(f"/{{'{'}}{{ record_id }}")
        assert resp.status_code == 200
        detail = resp.json().get("data", {})

        for key, value in apply_form_valid.items():
            if value is not None:
                assert detail.get(key) == value, f"Field {key}: expected {value}, got {detail.get(key)}"

    @pytest.mark.p1
    @pytest.mark.integration
    @pytest.mark.datascope
    def test_i007_datascope_isolation(self, applicant_session, cross_dept_session, apply_form_valid):
        """I007: 数据权限隔离 - 跨部门不可见"""
        helper, token = applicant_session
        cross_helper, cross_token = cross_dept_session

        resp = helper.post("{{ create_path }}", json_data=apply_form_valid)
        assert resp.status_code == 200
        record_id = resp.json().get("data")

        resp = cross_helper.get(f"/{{'{'}}{{ record_id }}")
        if resp.status_code == 200:
            data = resp.json()
            assert data.get("code") in [403, 500] or data.get("data") is None
