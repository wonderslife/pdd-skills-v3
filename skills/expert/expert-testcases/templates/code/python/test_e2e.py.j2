    @pytest.mark.p2
    @pytest.mark.integration
    @pytest.mark.concurrency
    def test_e005_concurrent_approval(self, dept_manager_session, apply_form_valid, approval_approve):
        """E005: 并发审批竞态条件"""
        import threading
        helper, _ = dept_manager_session
        results = []

        def approve():
            resp = helper.post("{{ approval_path }}", json_data=approval_approve)
            results.append(resp.status_code)

        threads = [threading.Thread(target=approve) for _ in range(3)]
        for t in threads:
            t.start()
        for t in threads:
            t.join()

        success_count = sum(1 for r in results if r == 200)
        assert success_count >= 1
