# {{ module_name }} 测试数据
# Auto-generated by expert-testcases v{{ skill_version }}
# Module: {{ module_code }}-{{ module_name }}

version: "1.0"
module:
  name: "{{ module_name }}"
  code: "{{ module_code }}"
  framework: "{{ framework }}"

test_users:
  applicant:
    username: "{{ applicant_username }}"
    password: "{{ applicant_password }}"
    dept: "{{ applicant_dept }}"
    dept_id: {{ applicant_dept_id }}
    role: "{{ applicant_role }}"

  dept_manager:
    username: "{{ dept_manager_username }}"
    password: "{{ dept_manager_password }}"
    dept: "{{ dept_manager_dept }}"
    dept_id: {{ dept_manager_dept_id }}
    role: "{{ dept_manager_role }}"

  leader:
    username: "{{ leader_username }}"
    password: "{{ leader_password }}"
    dept: "{{ leader_dept }}"
    dept_id: {{ leader_dept_id }}
    role: "{{ leader_role }}"

  admin:
    username: "{{ admin_username }}"
    password: "{{ admin_password }}"
    dept: "{{ admin_dept }}"
    dept_id: {{ admin_dept_id }}
    role: "admin"

  cross_dept_user:
    username: "{{ cross_dept_username }}"
    password: "{{ cross_dept_password }}"
    dept: "{{ cross_dept_dept }}"
    dept_id: {{ cross_dept_dept_id }}
    role: "{{ cross_dept_role }}"

apply_form_data:
  valid_draft:
{% for field in form_fields %}
    {{ field.name }}: {{ field.draft_value }}
{% endfor %}
    status: "01"

  valid_submit:
{% for field in form_fields %}
    {{ field.name }}: {{ field.submit_value | default(field.draft_value) }}
{% endfor %}
    status: "02"

  invalid_missing_required:
{% for field in required_fields %}
    {{ field.name }}: null
{% endfor %}

approval_data:
  approve_action:
    action: "approve"
    opinion: "同意"

  reject_action:
    action: "reject"
    opinion: "不同意，请补充材料"

  reject_no_opinion:
    action: "reject"
    opinion: null

{% if has_workflow %}
workflow_config:
  process_key: "{{ workflow_process_key }}"
  nodes:
{% for node in workflow_nodes %}
    {{ node.id }}:
      name: "{{ node.name }}"
      assignee_type: "{{ node.assignee_type }}"
      assignee_value: "{{ node.assignee_value }}"
{% if node.required_files %}
      required_files: {{ node.required_files }}
{% endif %}
{% endfor %}
{% endif %}

status_codes:
{% for code in status_codes %}
  "{{ code.code }}": "{{ code.meaning }}"
{% endfor %}

api_endpoints:
{% for ep in api_endpoints %}
  {{ ep.id }}:
    method: "{{ ep.method }}"
    path: "{{ ep.path }}"
    permission: "{{ ep.permission }}"
    description: "{{ ep.description }}"
{% endfor %}
